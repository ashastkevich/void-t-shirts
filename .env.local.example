# Supabase — get these from your Supabase project settings > API
# NEXT_PUBLIC_SUPABASE_URL  → "Project URL"
# NEXT_PUBLIC_SUPABASE_ANON_KEY → "Publishable key" (previously called "anon public")
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Prisma / Supabase DB — get from Supabase project settings > Database > Connection string (URI)
# Use the "Transaction" pooler URL on port 6543 for serverless (Vercel)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
